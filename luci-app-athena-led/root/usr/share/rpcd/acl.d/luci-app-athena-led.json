{
	"luci-app-athena-led": {
		"description": "Grant access to Athena LED configuration",
		"read": {
			"uci": [ "athena_led" ],
			"file": {
				"/var/run/athena-led.pid": [ "read" ],
				"/proc/*/cmdline": [ "read" ],
				"/etc/athena_led/anim": [ "list" ]
			}
		},
		"write": {
			"uci": [ "athena_led" ],
			"file": {
				"/etc/init.d/athena_led": [ "exec" ],
				"/etc/init.d/athena_led *": [ "exec" ]
			}
		}
	}
}
