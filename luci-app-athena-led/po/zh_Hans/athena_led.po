# ==================================
# 标题与状态 (v2.5.0 全量刷新, 与 settings.js 同步)
# ==================================
msgid "Athena LED Controller"
msgstr "雅典娜 LED 控制器"

msgid "JDCloud AX6600 LED matrix controller — dual GPIO backend, alerts, MQTT, automation."
msgstr "京东云 AX6600 点阵屏控制器 — 双 GPIO 后端 / 告警 / MQTT / 自动化。"

msgid "Running Status"
msgstr "运行状态"

msgid "Collecting data..."
msgstr "正在收集数据..."

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "Command failed with code %d"
msgstr "命令执行失败, 返回码 %d"

msgid "Service action \"%s\" executed."
msgstr "服务操作「%s」已执行。"

# ==================================
# 屏幕预览
# ==================================
msgid "Screen Preview"
msgstr "屏幕预览"

msgid "Simulates the 27×5 LED matrix. Supports digits, A-Z and symbols; unsupported characters are skipped (same as hardware)."
msgstr "模拟 27×5 点阵屏效果。支持数字、字母和符号；不支持的字符会被跳过 (与真实硬件行为一致)。"

msgid "Type text to preview..."
msgstr "输入要预览的文本..."

